{
  "name": "nc-backend-ts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/server.ts",
    "dev": "node --experimental-strip-types --watch src/server.ts",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "smoke": "node --experimental-strip-types --test test/smoke.test.ts",
    "contracts:check": "python contracts/validate_contracts.py",
    "review:routing": "node --experimental-strip-types scripts/review-routing-decisions.ts",
    "benchmark:retrieval": "node --experimental-strip-types scripts/benchmark_retrieval_engines.ts",
    "vectors:export": "python scripts/export_chroma_vectors.py all",
    "lancedb:import": "node --experimental-strip-types scripts/import_vector_export_to_lancedb.ts all"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2"
  }
}
