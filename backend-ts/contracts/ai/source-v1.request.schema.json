{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Source V1 Request",
  "type": "object",
  "required": ["messages"],
  "additionalProperties": false,
  "properties": {
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "google", "mistral"]
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "text"],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string"
          },
          "description": {
            "type": ["string", "null"]
          },
          "history": {
            "type": ["array", "object", "null"]
          },
          "sources": {
            "type": ["object", "null"]
          }
        }
      }
    }
  }
}
